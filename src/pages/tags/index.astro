---
import { getCollection } from 'astro:content';
import PageTopNav from '../../components/custom/PageTopNav.astro';
import ThemeProviderInline from '../../components/custom/ThemeProviderInline.astro';

import { getPublishedPosts } from '../../lib/blog';
import { getTagGroups, getTagHref } from '../../lib/tags';

const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const docs = await getCollection('docs', ({ data }) => !data.draft);
const posts = getPublishedPosts(await getCollection('blog'));
const allTagGroups = getTagGroups(docs, posts, basePath);
const wikiTagGroups = allTagGroups
    .map((group) => ({ ...group, items: group.items.filter((item) => item.collection === 'docs') }))
    .filter((group) => group.items.length > 0);
const blogTagGroups = allTagGroups
    .map((group) => ({ ...group, items: group.items.filter((item) => item.collection === 'blog') }))
    .filter((group) => group.items.length > 0);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Tags | LeeHK's Wiki</title>
        <meta
            name="description"
            content="Browse wiki documents and blog posts grouped by shared tags."
        />
        <ThemeProviderInline />
    </head>
    <body>
        <main class="tag-shell">
            <PageTopNav basePath={basePath} current="tags" />

            <section class="hero">
                <p class="eyebrow">Tags</p>
                <h1>Browse by tag.</h1>
                <p class="lede">
                    Shared topics from the wiki and the blog are grouped here so dated notes and evergreen docs stay
                    connected.
                </p>
            </section>

            <section class="tabs-shell" aria-label="Tag collections">
                <div class="tab-list" role="tablist" aria-label="Tag type">
                    <button class="tab-button is-active" type="button" role="tab" aria-selected="true" data-tab-trigger="all">
                        All
                    </button>
                    <button class="tab-button" type="button" role="tab" aria-selected="false" data-tab-trigger="wiki">
                        Wiki
                    </button>
                    <button class="tab-button" type="button" role="tab" aria-selected="false" data-tab-trigger="blog">
                        Blog
                    </button>
                </div>

                <div class="tab-panel is-active" role="tabpanel" data-tab-panel="all">
                    <div class="tag-grid" aria-label="All tag list">
                        {allTagGroups.map((group) => (
                            <a class="tag-card" href={getTagHref(group.label, basePath)}>
                                <span class="tag-label">#{group.label}</span>
                                <strong>{group.items.length} item{group.items.length > 1 ? 's' : ''}</strong>
                                <span class="tag-meta">
                                    {group.items.filter((item) => item.collection === 'docs').length} wiki /
                                    {` ${group.items.filter((item) => item.collection === 'blog').length} blog`}
                                </span>
                            </a>
                        ))}
                    </div>
                </div>

                <div class="tab-panel" role="tabpanel" hidden data-tab-panel="wiki">
                    <div class="tag-grid" aria-label="Wiki tag list">
                        {wikiTagGroups.map((group) => (
                            <a class="tag-card" href={getTagHref(group.label, basePath)}>
                                <span class="tag-label">#{group.label}</span>
                                <strong>{group.items.length} item{group.items.length > 1 ? 's' : ''}</strong>
                                <span class="tag-meta">{group.items.length} wiki</span>
                            </a>
                        ))}
                    </div>
                </div>

                <div class="tab-panel" role="tabpanel" hidden data-tab-panel="blog">
                    <div class="tag-grid" aria-label="Blog tag list">
                        {blogTagGroups.map((group) => (
                            <a class="tag-card" href={getTagHref(group.label, basePath)}>
                                <span class="tag-label">#{group.label}</span>
                                <strong>{group.items.length} item{group.items.length > 1 ? 's' : ''}</strong>
                                <span class="tag-meta">{group.items.length} blog</span>
                            </a>
                        ))}
                    </div>
                </div>
            </section>
        </main>

        <script>
            const tabButtons = Array.from(document.querySelectorAll('[data-tab-trigger]'));
            const tabPanels = Array.from(document.querySelectorAll('[data-tab-panel]'));

            const setActiveTab = (nextTab: string) => {
                tabButtons.forEach((button) => {
                    if (!(button instanceof HTMLButtonElement)) return;

                    const isActive = button.dataset.tabTrigger === nextTab;
                    button.classList.toggle('is-active', isActive);
                    button.setAttribute('aria-selected', String(isActive));
                });

                tabPanels.forEach((panel) => {
                    if (!(panel instanceof HTMLElement)) return;

                    const isActive = panel.dataset.tabPanel === nextTab;
                    panel.classList.toggle('is-active', isActive);
                    panel.hidden = !isActive;
                });
            };

            tabButtons.forEach((button) => {
                if (!(button instanceof HTMLButtonElement)) return;

                button.addEventListener('click', () => {
                    setActiveTab(button.dataset.tabTrigger ?? 'all');
                });
            });
        </script>
    </body>
</html>

<style>
    :root {
        color-scheme: dark;
        --bg: #020817;
        --bg-start: #020617;
        --bg-end: #020817;
        --glow-left: rgb(249 115 22 / 0.08);
        --glow-right: rgb(14 165 233 / 0.08);
        --panel: rgb(15 23 42 / 0.72);
        --border: rgb(59 130 246 / 0.18);
        --text: #f8fafc;
        --muted: #94a3b8;
        --control-bg: rgb(15 23 42 / 0.45);
        --control-border: rgb(59 130 246 / 0.3);
        --control-text: #e2e8f0;
        --panel-strong: color-mix(in srgb, #020817 22%, transparent);
    }

    :root[data-theme='light'] {
        color-scheme: light;
        --bg: #f8fafc;
        --bg-start: #fffaf5;
        --bg-end: #eef2ff;
        --glow-left: rgb(249 115 22 / 0.12);
        --glow-right: rgb(14 165 233 / 0.12);
        --panel: rgb(255 255 255 / 0.86);
        --border: rgb(148 163 184 / 0.24);
        --text: #0f172a;
        --muted: #64748b;
        --control-bg: rgb(255 255 255 / 0.84);
        --control-border: rgb(148 163 184 / 0.45);
        --control-text: #0f172a;
        --panel-strong: rgb(255 255 255 / 0.82);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family: ui-sans-serif, system-ui, sans-serif;
        background:
            radial-gradient(circle at top left, var(--glow-left), transparent 22rem),
            radial-gradient(circle at top right, var(--glow-right), transparent 24rem),
            linear-gradient(180deg, var(--bg-start) 0%, var(--bg-end) 100%);
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    .tag-shell {
        max-width: 72rem;
        margin: 0 auto;
        padding: 3rem 1rem 5rem;
    }

    .hero {
        max-width: 42rem;
        padding: 1rem 0 2rem;
    }

    .eyebrow {
        margin: 0;
        color: var(--muted);
        font-size: 0.875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0.75rem 0 0;
        font-size: 2.5rem;
        line-height: 1.15;
    }

    .lede {
        margin: 1rem 0 0;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.8;
    }

    .tag-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
        gap: 1rem;
    }

    .tabs-shell {
        display: grid;
        gap: 1.25rem;
    }

    .tab-list {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        width: fit-content;
        padding: 0.35rem;
        border: 1px solid var(--sl-color-hairline-shade);
        border-radius: 999px;
        background: var(--panel-strong);
        box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    }

    .tab-button {
        min-height: 2.35rem;
        padding: 0.55rem 0.95rem;
        border: 1px solid transparent;
        border-radius: 999px;
        color: var(--sl-color-gray-2);
        font-size: var(--sl-text-sm);
        font-weight: 600;
        font: inherit;
        background: transparent;
        cursor: pointer;
        transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
    }

    .tab-button:hover {
        background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
        color: var(--sl-color-white);
    }

    .tab-button.is-active {
        border-color: color-mix(in srgb, var(--sl-color-accent) 22%, var(--sl-color-hairline-shade));
        color: var(--sl-color-white);
        background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
        box-shadow: 0 0 0 1px rgb(255 255 255 / 0.03) inset;
    }

    .tab-panel {
        display: none;
    }

    .tab-panel.is-active {
        display: block;
    }

    .tag-card {
        display: grid;
        gap: 0.55rem;
        padding: 1.2rem;
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        background: var(--panel);
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .tag-card:hover {
        transform: translateY(-2px);
        border-color: rgb(249 115 22 / 0.45);
        background: color-mix(in srgb, var(--panel) 94%, black 6%);
    }

    .tag-label {
        color: #fdba74;
        font-size: 0.95rem;
        font-weight: 700;
    }

    strong {
        font-size: 1.2rem;
    }

    .tag-meta {
        color: var(--muted);
        font-size: 0.95rem;
    }
</style>
