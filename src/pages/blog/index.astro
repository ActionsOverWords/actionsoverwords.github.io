---
import { getCollection } from 'astro:content';
import { formatBlogDate, getPostHref } from '../../lib/blog';

const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (left, right) => right.data.date.getTime() - left.data.date.getTime()
);
const initialVisibleCount = 9;
const loadMoreCount = 9;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Blog | LeeHK's Wiki</title>
        <meta
            name="description"
            content="Recent implementation notes, learning logs, and retrospectives from the personal tech wiki."
        />
    </head>
    <body>
        <main class="blog-shell">
            <section class="hero">
                <div class="hero-copy">
                    <p class="eyebrow">Blog</p>
                    <h1>Welcome to the blog.</h1>
                    <p class="lede">
                        Explore recent notes on implementation details, technical decisions, Astro, and ongoing
                        experiments.
                    </p>
                    <div class="hero-actions">
                        <a class="primary-link" href={basePath}>Return to the wiki</a>
                    </div>
                </div>
            </section>

            <section class="posts-section" aria-label="Blog posts">
                <div class="search-shell">
                    <label class="sr-only" for="blog-search">Search blog posts</label>
                    <input
                        id="blog-search"
                        class="search-input"
                        type="search"
                        placeholder="Search articles..."
                        autocomplete="off"
                    />
                </div>

                <div class="posts-grid">
                    {posts.map((post, index) => (
                        <article
                            class="post-card"
                            data-index={index}
                            data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase()}
                        >
                            <a href={getPostHref(post, basePath)} aria-label={post.data.title}>
                                <div class="post-meta">
                                    <time datetime={post.data.date.toISOString()}>
                                        {formatBlogDate(post.data.date)}
                                    </time>

                                    {post.data.tags.length > 0 && (
                                        <span class="tag-group">
                                            {post.data.tags.slice(0, 2).map((tag) => (
                                                <span class="tag">#{tag}</span>
                                            ))}
                                        </span>
                                    )}
                                </div>

                                <h2>{post.data.title}</h2>
                                <p>{post.data.description}</p>
                            </a>
                        </article>
                    ))}
                </div>

                {posts.length > initialVisibleCount && (
                    <div class="load-more-shell">
                        <button
                            id="load-more-posts"
                            class="load-more-button"
                            type="button"
                            data-initial-visible-count={initialVisibleCount}
                            data-load-more-count={loadMoreCount}
                        >
                            Load more
                        </button>
                    </div>
                )}
            </section>
        </main>

        <script>
            const searchInput = document.querySelector('#blog-search');
            const postCards = Array.from(document.querySelectorAll('.post-card'));
            const loadMoreButton = document.querySelector('#load-more-posts');
            const initialVisibleCount = Number(loadMoreButton?.dataset.initialVisibleCount ?? '6');
            const loadMoreCount = Number(loadMoreButton?.dataset.loadMoreCount ?? '6');
            let visibleCount = initialVisibleCount;

            const updateVisibleCards = (query) => {
                const normalizedQuery = query.trim().toLowerCase();
                let matchedCount = 0;

                postCards.forEach((card) => {
                    if (!(card instanceof HTMLElement)) return;

                    const searchable = card.dataset.search ?? '';
                    const isMatch = !normalizedQuery || searchable.includes(normalizedQuery);

                    if (!isMatch) {
                        card.style.display = 'none';
                        return;
                    }

                    matchedCount += 1;
                    card.style.display = matchedCount <= visibleCount ? '' : 'none';
                });

                if (loadMoreButton instanceof HTMLButtonElement) {
                    loadMoreButton.style.display = matchedCount > visibleCount ? '' : 'none';
                }
            };

            updateVisibleCards('');

            searchInput?.addEventListener('input', (event) => {
                const target = event.currentTarget;

                if (!(target instanceof HTMLInputElement)) return;

                visibleCount = initialVisibleCount;
                updateVisibleCards(target.value);
            });

            loadMoreButton?.addEventListener('click', () => {
                visibleCount += loadMoreCount;
                const query = searchInput instanceof HTMLInputElement ? searchInput.value : '';
                updateVisibleCards(query);
            });
        </script>
    </body>
</html>

<style>
    :root {
        color-scheme: dark;
        --bg: #020817;
        --panel: rgb(24 24 27 / 0.6);
        --panel-hover: rgb(24 24 27 / 0.8);
        --text: #f8fafc;
        --muted: #a1a1aa;
        --muted-2: #94a3b8;
        --border: rgb(39 39 42 / 0.9);
        --accent: #a78bfa;
    }

    * {
        box-sizing: border-box;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family: ui-sans-serif, system-ui, sans-serif;
        background:
            radial-gradient(circle at top left, rgb(249 115 22 / 0.06), transparent 18rem),
            radial-gradient(circle at top right, rgb(59 130 246 / 0.06), transparent 22rem),
            linear-gradient(180deg, #020617 0%, #020817 100%);
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    .blog-shell {
        max-width: 72rem;
        margin: 0 auto;
        padding: 3rem 1rem 5rem;
    }

    .hero {
        padding: 2.5rem 0 1.25rem;
    }

    .hero-copy {
        max-width: 40rem;
    }

    .eyebrow {
        margin: 0;
        color: var(--muted);
        font-size: 0.875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0.75rem 0 0;
        color: #d4d4d8;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 2.25rem;
        line-height: 1.25;
        font-weight: 700;
        letter-spacing: -0.03em;
    }

    .lede {
        margin: 1.5rem 0 0;
        color: #a1a1aa;
        font-size: 1.125rem;
        line-height: 1.75rem;
        max-width: 44rem;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .primary-link {
        display: inline-flex;
        align-items: center;
        min-height: 2.5rem;
        padding: 0.75rem 1rem;
        border: 1px solid rgb(59 130 246 / 0.3);
        border-radius: 999px;
        color: #e2e8f0;
        background: rgb(15 23 42 / 0.45);
    }

    .posts-section {
        max-width: 80rem;
        margin: 0 auto;
        padding: 2rem 0 0;
    }

    .search-shell {
        margin-bottom: 1.5rem;
    }

    .search-input {
        width: 100%;
        height: 3.5rem;
        padding: 0.5rem 1.25rem;
        border: 1px solid rgb(30 41 59 / 1);
        border-radius: 0.75rem;
        background: rgb(15 23 42 / 0.92);
        color: #e2e8f0;
        font: inherit;
        transition:
            border-color 160ms ease,
            box-shadow 160ms ease;
    }

    .search-input::placeholder {
        color: #64748b;
    }

    .search-input:focus {
        outline: none;
        border-color: rgb(59 130 246 / 0.9);
        box-shadow: 0 0 0 3px rgb(59 130 246 / 0.2);
    }

    .posts-grid {
        display: grid;
        gap: 2rem;
    }

    .load-more-shell {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .load-more-button {
        min-height: 2.75rem;
        padding: 0.75rem 1.25rem;
        border: 1px solid rgb(59 130 246 / 0.3);
        border-radius: 999px;
        background: rgb(15 23 42 / 0.45);
        color: #e2e8f0;
        font: inherit;
        cursor: pointer;
        transition:
            transform 160ms ease,
            background-color 160ms ease,
            border-color 160ms ease;
    }

    .load-more-button:hover {
        transform: translateY(-1px);
        background: rgb(15 23 42 / 0.7);
        border-color: rgb(59 130 246 / 0.5);
    }

    .post-card {
        position: relative;
        width: 100%;
        padding: 1.5rem;
        border-radius: 1rem;
        background: var(--panel);
        transition:
            background-color 180ms ease,
            box-shadow 180ms ease,
            transform 180ms ease;
    }

    .post-card:hover {
        background: var(--panel-hover);
        box-shadow: 0 20px 32px rgb(0 0 0 / 0.3);
        transform: translateY(-2px);
    }

    .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 0.75rem;
        color: var(--muted);
        font-size: 0.875rem;
    }

    .tag-group {
        display: flex;
        gap: 0.5rem;
    }

    .tag {
        padding: 0.125rem 0.5rem;
        border-radius: 999px;
        background: #27272a;
        color: #d4d4d8;
        font-size: 0.75rem;
    }

    h2 {
        margin: 0;
        color: #f4f4f5;
        font-size: 1.25rem;
        font-weight: 600;
        line-height: 1.75rem;
        transition: color 180ms ease;
    }

    .post-card:hover h2 {
        color: var(--accent);
    }

    .post-card p:last-child {
        margin: 0.75rem 0 0;
        color: #a1a1aa;
        font-size: 0.875rem;
        line-height: 1.5rem;
    }

    @media (min-width: 40rem) {
        .posts-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (min-width: 64rem) {
        .posts-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 40rem) {
        .blog-shell {
            padding-top: 2rem;
        }

        .hero {
            padding-top: 1.5rem;
        }

        h1 {
            font-size: 2rem;
            line-height: 1.2;
        }

        .lede {
            margin-top: 1rem;
            font-size: 1rem;
        }
    }
</style>
